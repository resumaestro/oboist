{
  "name": "resumaestro-oboist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*.ts"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --secrets-file .env",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "types": "wrangler types --include-runtime false",
    "check": "npm run types && npm run typecheck && npm test && wrangler deploy --dry-run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.100.0"
  }
}
